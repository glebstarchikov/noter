# Core app configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# AI provider
OPENAI_API_KEY=your-openai-api-key

# optional — was used by the processing-worker pipeline, removed in Phase 1.5
# (self-host deployments now use the same direct note-generation path as SaaS)
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# CRON_SECRET=your-random-worker-secret

# Optional: development auth redirect override
# Example: http://localhost:3000/auth/callback
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=

# Optional: Upstash rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: browser-based realtime transcription
DEEPGRAM_API_KEY=
# Required in production: enables short-lived temporary keys so the main API
# key is never exposed to the browser. Without this, the raw key is returned.
DEEPGRAM_PROJECT_ID=

# Optional: error tracking
NEXT_PUBLIC_SENTRY_DSN=

# Optional: web search enrichment
TAVILY_API_KEY=

# Optional: lock down public sign-ups for the deployed reference instance.
# When set to "true", the /auth/sign-up route renders a "sign-ups closed"
# message, the sign-up CTAs on the login + landing pages are hidden or
# redirected to /auth/login, and the sign-up URL is removed from the sitemap.
# Self-hosters should leave this unset (or set to "false") to keep sign-ups open.
NEXT_PUBLIC_DISABLE_SIGNUP=
