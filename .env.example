# Core app configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# AI provider
OPENAI_API_KEY=your-openai-api-key

# optional — was used by the processing-worker pipeline, removed in Phase 1.5
# (self-host deployments now use the same direct note-generation path as SaaS)
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# CRON_SECRET=your-random-worker-secret

# Optional: development auth redirect override
# Example: http://localhost:3000/auth/callback
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=

# Optional: Upstash rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: browser-based realtime transcription
DEEPGRAM_API_KEY=
# Required in production: enables short-lived temporary keys so the main API
# key is never exposed to the browser. Without this, the raw key is returned.
DEEPGRAM_PROJECT_ID=

# Optional: error tracking
NEXT_PUBLIC_SENTRY_DSN=

# Optional: web search enrichment
TAVILY_API_KEY=

# Optional: hide the sign-up UI on a deployment.
#
# IMPORTANT: this env var is UI-ONLY. It hides the sign-up form, swaps the
# landing CTA to "Sign in", and removes the sign-up URL from the sitemap —
# but it does NOT block account creation. supabase.auth.signUp() runs
# entirely client-side, so a determined caller can call it from the browser
# console and bypass this UI flag entirely.
#
# To actually block new accounts on a deployment, disable sign-ups at the
# Supabase project level:
#   Supabase Dashboard → Authentication → Sign In / Up
#   → toggle "Allow new users to sign up" off
#
# This is the master switch — it blocks all sign-up methods at once
# (email/password, magic link, OAuth providers). Existing users can still
# sign in.
#
# Set both this env var (UI) AND the Supabase toggle (enforcement) for the
# full closed-for-signups experience. Self-hosters who want sign-ups open
# leave this unset and keep the Supabase Dashboard toggle on.
NEXT_PUBLIC_DISABLE_SIGNUP=
