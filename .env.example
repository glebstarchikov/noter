# Core app configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# AI provider
# Required: set one of these.
OPENAI_API_KEY=your-openai-api-key
# AI_GATEWAY_API_KEY=your-vercel-ai-gateway-api-key

# Async processing
# Required if you want the background worker and queued meeting processing.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
CRON_SECRET=your-random-worker-secret

# Optional: development auth redirect override
# Example: http://localhost:3000/auth/callback
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=

# Optional: Upstash rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: browser-based realtime transcription
DEEPGRAM_API_KEY=
# Required in production: enables short-lived temporary keys so the main API
# key is never exposed to the browser. Without this, the raw key is returned.
DEEPGRAM_PROJECT_ID=

# Optional: error tracking
NEXT_PUBLIC_SENTRY_DSN=

# Optional: web search enrichment
TAVILY_API_KEY=
